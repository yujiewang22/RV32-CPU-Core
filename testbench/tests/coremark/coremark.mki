OFILES = crt0.o core_main.o core_list_join.o core_matrix.o core_state.o core_util.o core_portme.o ee_printf.o printf.o
TEST_CFLAGS = -g -O3

TEST_CFLAGS += -DFLAGS_STR=\""$(TEST_CFLAGS)"\"
TEST_CFLAGS += -DITERATIONS=1
TEST_CFLAGS += -DHAS_FLOAT=0
TEST_CFLAGS += -HAS_TIME_H=0
TEST_CFLAGS += -USE_CLOCK=0
TEST_CFLAGS += -HAS_STDIO=0
TEST_CFLAGS += -HAS_PRINTF=0

